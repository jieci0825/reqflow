{
    "name": "@coderjc/reqflow",
    "version": "0.0.5",
    "description": "一个基于插件与中间件的请求管线框架，支持 fetch、axios 等多种适配器。",
    "author": "coderjc <coderjc@qq.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jieci0825/reqflow.git"
    },
    "homepage": "https://github.com/jieci0825/reqflow#readme",
    "bugs": {
        "url": "https://github.com/jieci0825/reqflow/issues"
    },
    "keywords": [
        "http",
        "request",
        "fetch",
        "middleware",
        "plugin",
        "pipeline",
        "sse",
        "retry",
        "cache",
        "token",
        "typescript"
    ],
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./adapters/fetch": {
            "import": {
                "types": "./dist/adapters/fetch.d.mts",
                "default": "./dist/adapters/fetch.mjs"
            },
            "require": {
                "types": "./dist/adapters/fetch.d.cts",
                "default": "./dist/adapters/fetch.cjs"
            }
        },
        "./plugins": {
            "import": {
                "types": "./dist/plugins.d.mts",
                "default": "./dist/plugins.mjs"
            },
            "require": {
                "types": "./dist/plugins.d.cts",
                "default": "./dist/plugins.cjs"
            }
        },
        "./sse": {
            "import": {
                "types": "./dist/sse/index.d.mts",
                "default": "./dist/sse/index.mjs"
            },
            "require": {
                "types": "./dist/sse/index.d.cts",
                "default": "./dist/sse/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "build": "tsdown",
        "prepublishOnly": "npm run build",
        "release": "bumpp && npm publish --access public",
        "server": "node playgrounds/server.js"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "bumpp": "^11.0.1",
        "tsdown": "^0.21.7",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
