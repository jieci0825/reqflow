{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vitest/globals", "node"],
        "isolatedModules": true,
        "verbatimModuleSyntax": true
    },
    "include": ["src", "tests"],
    "exclude": ["node_modules", "dist"]
}
